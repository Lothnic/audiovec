# ── audiovec — Web App Environment Variables ──────────────────────────────────
# Copy this file to .env.local for local development.
# On Vercel, set these in the Project Settings → Environment Variables.

# Model path (relative to NEXT_PUBLIC_PROJECT_ROOT or absolute).
# Defaults to "../models/crnn-transformer.onnx" (from web/ up to project root).
# On Vercel, set this to match the path traced in next.config.ts.
# MODEL_PATH=../models/crnn-transformer.onnx

# Port for the dev server (Next.js defaults to 3000).
# PORT=3000
